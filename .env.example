# snapMULTI Environment Configuration
# Copy this file to .env and update with your values
# Run: ./scripts/deploy.sh to auto-detect hardware and configure

# Music library path (auto-detected by deploy.sh)
# deploy.sh scans /media/*, /mnt/*, ~/Music for audio files
# If none found, defaults to /media/music
MUSIC_PATH=/media/music

# Timezone
TZ=Europe/Berlin

# User/Group for container processes
# These should match your host user to avoid permission issues
PUID=1000
PGID=1000

# ============================================================
# Service Names (how they appear in AirPlay/Spotify apps)
# ============================================================
# By default, services use hostname + suffix (e.g., "raspberrypi AirPlay")
# Override to customize the displayed name:
#AIRPLAY_NAME=Living Room AirPlay
#SPOTIFY_NAME=Living Room Spotify

# Tidal Connect device name (ARM only - Pi 3/4/5)
# How the device appears in the Tidal app's cast menu
#TIDAL_NAME=Living Room Tidal

# ============================================================
# Docker Compose Profiles (auto-configured by deploy.sh)
# ============================================================
# Tidal Connect is ARM-only. deploy.sh enables it automatically on ARM.
# Uncomment to enable manually on ARM systems not using deploy.sh:
#COMPOSE_PROFILES=tidal

# ============================================================
# Resource Limits (auto-configured by deploy.sh)
# ============================================================
# deploy.sh detects your hardware and sets appropriate limits.
# Override manually if needed.
#
# Profiles:
#   minimal     - Pi Zero 2 W, Pi 3, <2GB RAM
#   standard    - Pi 4 2GB, 2-4GB RAM
#   performance - Pi 4 4GB+, Pi 5, 8GB+ RAM
#
# To reconfigure: ./scripts/deploy.sh --profile <profile>
# ============================================================

# Snapserver (core audio server) — measured idle: 87M
#SNAPSERVER_MEM_LIMIT=192M
#SNAPSERVER_MEM_RESERVE=96M
#SNAPSERVER_CPU_LIMIT=1.0

# AirPlay (shairport-sync) — measured idle: 18M
#AIRPLAY_MEM_LIMIT=64M
#AIRPLAY_MEM_RESERVE=32M
#AIRPLAY_CPU_LIMIT=0.5

# Spotify Connect (go-librespot) — measured idle: 22M, active: ~180M
#SPOTIFY_MEM_LIMIT=128M
#SPOTIFY_MEM_RESERVE=64M
#SPOTIFY_CPU_LIMIT=0.5

# MPD (Music Player Daemon) — measured idle: 90M, peak during library scan
#MPD_MEM_LIMIT=256M
#MPD_MEM_RESERVE=128M
#MPD_CPU_LIMIT=1.0

# MPD healthcheck start period (auto-detected by deploy.sh)
# deploy.sh sets 300s for NFS/network mounts, 30s for local storage
# Increase for very large libraries that take longer to initialize
# Also used by myMPD (must wait for MPD to be ready before starting)
#MPD_START_PERIOD=60s

# myMPD (Web UI) — measured idle: 8M
#MYMPD_MEM_LIMIT=64M
#MYMPD_MEM_RESERVE=32M
#MYMPD_CPU_LIMIT=0.5

# Tidal Connect (ARM only) — measured idle: 32M
#TIDAL_MEM_LIMIT=96M
#TIDAL_MEM_RESERVE=48M
#TIDAL_CPU_LIMIT=0.5

# Metadata Service (cover art + track info) — measured idle: 52M
# EXTERNAL_HOST: hostname/IP for artwork URLs sent to clients (auto-detected via FQDN).
# Set explicitly if artwork doesn't appear on clients (auto-detection may return localhost).
#EXTERNAL_HOST=
# SNAPMULTI_VERSION: set automatically by deploy.sh from git tags or .version file
#SNAPMULTI_VERSION=0.3.6
#METADATA_MEM_LIMIT=128M
#METADATA_MEM_RESERVE=64M
#METADATA_CPU_LIMIT=0.5

# ============================================================
# Automatic Updates (opt-in)
# ============================================================
# Watchtower monitors running containers and auto-pulls new :latest images.
# Only updates lollonet/snapmulti-* images; pinned versions are excluded.
#
# AUTO_UPDATE=true              # Enable Watchtower (adds auto-update profile)
# UPDATE_SCHEDULE=0 0 3 * * *   # Cron schedule (default: daily 3 AM)
# UPDATE_NOTIFY_URL=            # Notification URL (shoutrrr format: slack://, smtp://, etc.)
