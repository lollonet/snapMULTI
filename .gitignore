# Environment variables
.env

# Triad workflow run artifacts (run-local, not for VCS)
.agents/
# Triad scripts symlink (host-local convenience)
scripts/triad

# snapMULTI runtime data (project-root only — sub-trees may have
# audio/ as a legitimate path, e.g. scripts/common/audio/ ships
# pre-recorded smoke-result tones)
/data/
/audio/
/artwork/
/mympd/

# MPD runtime data (but not config)
mpd/data/
mpd/playlists/

# MPD database and logs
mpd/data/mpd.db
mpd/data/mpd.log
mpd/data/mpd.state
mpd/data/sticker.sql

# Docker volumes
*.log

# Python cache
__pycache__/

# Editor files
.*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Claude session files
.claude/

# Backup files
.backups/
.version
